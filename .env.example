# valuate-web environment variables.
# Copy to .env.local (gitignored) for local dev, or set in the Vercel project UI.

# URL of the Railway-hosted valuate-api. The Next.js rewrite in next.config.ts
# proxies /api/* → ${NEXT_PUBLIC_VALUATE_API}/* so the browser only sees the
# Vercel origin (no CORS).
NEXT_PUBLIC_VALUATE_API="https://valuate-api.up.railway.app"
