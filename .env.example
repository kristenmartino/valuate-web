# valuate-web environment variables.
# Copy to .env.local (gitignored) for local dev, or set in the Vercel project UI.

# URL of the Railway-hosted valuate-api. The Next.js rewrite in next.config.ts
# proxies /api/* → ${NEXT_PUBLIC_VALUATE_API}/* so the browser only sees the
# Vercel origin (no CORS).
NEXT_PUBLIC_VALUATE_API="https://valuate-api.up.railway.app"

# Optional. Bearer token for the backend's /override endpoint. This is a
# NON-PUBLIC env var (no NEXT_PUBLIC_ prefix) so it stays server-side —
# proxy.ts reads it via process.env on the Vercel edge and injects it as
# `Authorization: Bearer <token>` onto override requests. Must match the
# VALUATE_OVERRIDE_TOKEN set on the backend (Railway env var of the same
# name). When unset on both sides, /override runs unauthenticated.
# VALUATE_OVERRIDE_TOKEN="same-token-as-backend"
